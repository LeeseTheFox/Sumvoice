# =============================================================================
# Sumvoice – example environment file
# Copy this file to .env and fill in your values before starting the bot.
# =============================================================================

# -----------------------------------------------------------------------------
# Bot credentials
# -----------------------------------------------------------------------------

# Telegram bot token – obtain from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Groq API key – obtain from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# -----------------------------------------------------------------------------
# Admin configuration
# -----------------------------------------------------------------------------

# Your personal Telegram user ID (integer).
# The admin can use privileged commands such as /whitelist and /toggle_whitelist.
# You can get your ID by messaging @userinfobot on Telegram.
ADMIN_ID=your_telegram_user_id_here

# -----------------------------------------------------------------------------
# Whitelist configuration  (bot only)
# -----------------------------------------------------------------------------

# Set to "true" to restrict the bot to whitelisted users only.
# Set to "false" (default) to allow anyone to use the bot.
WHITELIST_ENABLED=false

# Comma-separated list of Telegram user IDs that are allowed to use the bot
# when WHITELIST_ENABLED=true. Managed at runtime via the /whitelist command.
WHITELIST_IDS=

# -----------------------------------------------------------------------------
# Userbot credentials  (sumvoice_userbot.py only)
# -----------------------------------------------------------------------------

# Pyrogram API credentials – obtain from https://my.telegram.org
PYROGRAM_API_ID=your_pyrogram_api_id_here
PYROGRAM_API_HASH=your_pyrogram_api_hash_here
